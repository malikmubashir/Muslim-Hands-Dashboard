# N3O Webhook Integration
# Add these to your Vercel Environment Variables

# Cron job secret (for securing the webhook processor)
CRON_SECRET=your_secret_key_here

# Vercel KV (queue storage)
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Vercel Blob (aggregate storage)
BLOB_READ_WRITE_TOKEN=

# N3O API (optional, for manual resync)
N3O_API_KEY=
N3O_API_BASE_URL=https://api.n3o.ltd

# Feature flags
WEBHOOK_ENABLED=true
WEBHOOK_LOG_PAYLOADS=false
WEBHOOK_ENABLE_SIGNATURE_VERIFICATION=false
